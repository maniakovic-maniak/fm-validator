# FM Validator — Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API (required)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Drive (required)
# Create OAuth2 Desktop App credentials at console.cloud.google.com
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id-here

# Email notifications via Resend (required)
RESEND_API_KEY=re_your-key-here
NOTIFY_EMAIL=you@youremail.com

# Server (optional — defaults shown)
PORT=3000
