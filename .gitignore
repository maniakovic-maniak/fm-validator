# Secrets — never commit
.env
.env.*
!.env.example
credentials.json
token.json
*.pem
*.key

# Runtime data
node_modules/
uploads/*
!uploads/.gitkeep
processed/*
!processed/.gitkeep
logs/*.log
*.log

# OS / editor
.DS_Store
.vscode/

# Diagnostic dumps contain raw model content — never commit
logs/
*.old
__pycache__/
*.pyc

# bug-scan-agent.js's transient per-scan cache — regenerated on every
# scan, never meant to be committed (see scripts/bug-scan-agent.js)
.bug-scan-findings.json
